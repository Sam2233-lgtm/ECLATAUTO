# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."

# ─────────────────────────────────────────────
# Database (PostgreSQL via Supabase)
# Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543, pgbouncer=true)
# Use "Session" mode URL for DIRECT_URL (port 5432)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-PASSWORD]@aws-0-ca-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-PASSWORD]@aws-0-ca-central-1.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────
# NextAuth
# Generate a secret: openssl rand -base64 32
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="https://your-site.netlify.app"

# ─────────────────────────────────────────────
# Email (optional — console logging used if not set)
# ─────────────────────────────────────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="yourpassword"
# SMTP_FROM="Eclat Auto <noreply@eclatauto.ca>"

# Identifiants admin par défaut (après seed)
# Email: admin@eclatauto.ca
# Mot de passe: Admin123!
